{% if theme_data %}
:root {
    --clr-primary: {{ theme_data.colors.primary }};
    --clr-secondary: {{ theme_data.colors.secondary }};
    --clr-text: {{ theme_data.colors.text }};
    --clr-text-muted: {{ theme_data.colors.textMuted }};
    --clr-error: {{ theme_data.colors.error }};
    --bg-title: {{ theme_data.gradients.slide2 }};
    --bg-body: {{ theme_data.gradients.slide1 }};
    --bg-section: {{ theme_data.gradients.slide3 }};
    --font-heading: {{ theme_data.fonts.heading }};
    --font-body: {{ theme_data.fonts.body }};
    --font-mono: {{ theme_data.fonts.monospace }};
    --fs-h1: {{ theme_data.sizes.titleHeading }};
    --fs-slide-h: {{ theme_data.sizes.slideHeading }};
    --fs-section-h: {{ theme_data.sizes.sectionHeading }};
    --fs-body: {{ theme_data.sizes.body }};
    --fs-small: {{ theme_data.sizes.small }};
    --slide-padding: {{ theme_data.spacing.slidePadding }};
    --element-margin: {{ theme_data.spacing.elementMargin }};
    --line-height: {{ theme_data.spacing.lineHeight }};
}
{% else %}
:root {
    --clr-primary: currentColor;
    --clr-secondary: currentColor;
    --clr-text: inherit;
    --clr-text-muted: inherit;
    --clr-error: #dc3545;
    --bg-title: transparent;
    --bg-body: transparent;
    --bg-section: transparent;
    --font-heading: inherit;
    --font-body: inherit;
    --font-mono: monospace;
    --fs-h1: 2em;
    --fs-slide-h: 1.3em;
    --fs-section-h: 1.8em;
    --fs-body: 0.75em;
    --fs-small: 0.65em;
    --slide-padding: 1.5em 2.5em;
    --element-margin: 0.6em;
    --line-height: 1.6;
}
{% endif %}
:root {
    --slide-width: 1280px;
    --slide-height: 720px;
}
.reveal .slides section {
    text-align: left;
    height: 100%;
    box-sizing: border-box;
    font-family: var(--font-body);
    color: var(--clr-text);
}
/* Title slide */
.reveal .slides section.slide-title {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--bg-title);
}
.reveal .slides section.slide-title h1 {
    font-size: var(--fs-h1, 2em);
    font-weight: 800;
    color: var(--clr-primary);
    margin-bottom: 0.3em;
    text-shadow: none;
    animation: fadeInUp 1s ease;
    font-family: var(--font-heading);
}
.reveal .slides section.slide-title h2 {
    font-size: 1em;
    opacity: 0.85;
    font-weight: 400;
    animation: fadeInUp 1s ease 0.2s both;
}
.reveal .slides section.slide-title .meta {
    margin-top: 1.5em;
    font-size: var(--fs-small, 0.65em);
    opacity: 0.6;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    animation: fadeInUp 1s ease 0.4s both;
}
/* Shared: slide body text (TitleSlide.body, SectionBreakSlide.body) */
.reveal .slides .slide-body {
    font-size: var(--fs-small, 0.65em);
    opacity: 0.8;
    margin-top: 0.5em;
    line-height: var(--line-height, 1.6);
}
/* Content slides */
.reveal .slides section.slide-content {
    background: var(--bg-body);
    padding: var(--slide-padding, 1.5em 2.5em);
}
.reveal .slides section.slide-content h2 {
    font-size: var(--fs-slide-h, 1.3em);
    font-weight: 700;
    color: var(--clr-primary);
    margin-bottom: var(--element-margin, 0.6em);
    border-bottom: 3px solid var(--clr-primary);
    padding-bottom: 0.2em;
    display: inline-block;
    font-family: var(--font-heading);
}
.reveal .slides section.slide-content ul {
    margin-left: 0.5em;
    font-size: var(--fs-body, 0.75em);
    line-height: var(--line-height, 1.6);
}
.reveal .slides section.slide-content li {
    margin-bottom: 0.4em;
}
.reveal .slides section.present.slide-content li {
    opacity: 0;
    animation: fadeInUp 0.6s ease both;
    animation-delay: calc(var(--n, 0) * 0.1s);
}
.reveal .slides section.slide-content li::marker {
    color: var(--clr-primary);
    font-size: 1.2em;
}
/* Icon styling */
.icon {
    font-size: 1.2em;
    margin-right: 0.3em;
}
/* Image slides */
.reveal .slides section.slide-image {
    background: var(--bg-body);
    padding: var(--slide-padding, 1.5em 2.5em);
}
.reveal .slides section.slide-image h2 {
    font-size: var(--fs-slide-h, 1.3em);
    font-weight: 700;
    color: var(--clr-primary);
    margin-bottom: 0.5em;
    font-family: var(--font-heading);
}
.reveal .img-grid {
    display: grid;
    gap: 1.5em;
    align-items: center;
    height: 75%;
}
.reveal .img-grid.right { grid-template-columns: 1fr 1.2fr; }
.reveal .img-grid.left  { grid-template-columns: 1.2fr 1fr; }
.reveal .img-grid img {
    width: 100%;
    height: auto;
    max-height: 320px;
    object-fit: cover;
    border-radius: 12px;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.2);
    animation: floatImage 6s ease-in-out infinite;
}
@keyframes floatImage {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
}
.reveal .img-grid ul {
    font-size: var(--fs-body, 0.75em);
    line-height: var(--line-height, 1.6);
    list-style: none;
    padding: 0;
    margin: 0;
}
.reveal .img-grid li {
    margin-bottom: 0.5em;
    padding-left: 1.5em;
    position: relative;
}
.reveal .slides section.present .img-grid li {
    opacity: 0;
    animation: fadeInUp 0.6s ease both;
    animation-delay: calc(var(--n, 0) * 0.1s);
}
.reveal .img-grid li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--clr-primary);
    font-weight: bold;
}
.reveal .img-caption {
    font-size: var(--fs-small, 0.65em);
    opacity: 0.7;
    margin-top: 0.8em;
    font-style: italic;
    text-align: center;
}
/* Two-column */
.reveal .slides section.slide-two-column {
    background: var(--bg-body);
    padding: var(--slide-padding, 1.5em 2.5em);
}
.reveal .slides section.slide-two-column > h2 {
    font-size: var(--fs-slide-h, 1.3em);
    font-weight: 700;
    color: var(--clr-primary);
    margin-bottom: var(--element-margin, 0.6em);
    text-align: center;
    font-family: var(--font-heading);
}
.reveal .two-col-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2em;
    margin-top: 0.5em;
}
.reveal .two-col-grid > div {
    background: rgba(128,128,128,0.05);
    border-radius: 16px;
    padding: 1em;
    border: 1px solid rgba(128,128,128,0.1);
}
.reveal .col-title {
    font-weight: 700;
    font-size: 0.85em;
    margin-bottom: var(--element-margin, 0.6em);
    padding-bottom: 0.4em;
    border-bottom: 2px solid;
    font-family: var(--font-heading);
}
.reveal .two-col-grid > div:first-child .col-title {
    color: var(--clr-primary);
    border-color: var(--clr-primary);
}
.reveal .two-col-grid > div:last-child .col-title {
    color: var(--clr-error);
    border-color: var(--clr-error);
}
.reveal .two-col-grid ul {
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: var(--fs-small, 0.65em);
    line-height: var(--line-height, 1.6);
}
.reveal .two-col-grid li {
    margin-bottom: 0.3em;
}
.reveal .slides section.present .two-col-grid li {
    opacity: 0;
    animation: fadeInUp 0.5s ease both;
    animation-delay: calc(var(--n, 0) * 0.1s);
}
/* Section break */
.reveal .slides section.slide-section-break {
    background: var(--bg-section);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
}
.reveal .slides section.slide-section-break h2 {
    font-size: var(--fs-section-h, 1.8em);
    font-weight: 800;
    margin-bottom: 0.3em;
    font-family: var(--font-heading);
}
.reveal .slides section.slide-section-break h3 {
    font-size: 1em;
    font-weight: 400;
    opacity: 0.9;
}
/* Quote */
.reveal .slides section.slide-quote {
    background: var(--bg-body);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
}
.reveal .slides section.slide-quote blockquote {
    font-size: 1.3em;
    font-style: italic;
    line-height: var(--line-height, 1.6);
    border: none;
    background: transparent;
    max-width: 85%;
    padding: 0;
    font-weight: 300;
}
.reveal .slides section.slide-quote blockquote::before {
    content: "\201C";
    font-size: 3em;
    line-height: 0.1em;
    vertical-align: -0.4em;
    opacity: 0.3;
    color: var(--clr-primary);
}
.reveal .attribution {
    margin-top: 1.5em;
    font-size: 0.8em;
    opacity: 0.8;
    color: var(--clr-primary);
}
/* Table */
.reveal .slides section.slide-table {
    background: var(--bg-body);
    padding: var(--slide-padding, 1.5em 2.5em);
}
.reveal .slides section.slide-table h2 {
    font-size: var(--fs-slide-h, 1.3em);
    font-weight: 700;
    color: var(--clr-primary);
    margin-bottom: var(--element-margin, 0.6em);
    text-align: center;
    font-family: var(--font-heading);
}
.reveal table {
    width: 100%;
    font-size: var(--fs-body, 0.75em);
    border-collapse: separate;
    border-spacing: 0;
    background: rgba(128,128,128,0.03);
    border-radius: 10px;
    overflow: hidden;
}
.reveal table th {
    background: rgba(128,128,128,0.1);
    padding: 0.7em;
    text-align: left;
    font-weight: 600;
    color: var(--clr-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
}
.reveal table td {
    padding: 0.5em 0.7em;
    border-bottom: 1px solid rgba(128,128,128,0.1);
}
.reveal table tr:last-child td { border-bottom: none; }
.reveal table tr:hover td { background: rgba(128,128,128,0.05); }
/* Animations */
@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}
@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
}
/* Controls styling */
.reveal .controls {
    color: var(--clr-primary);
}
.reveal .progress {
    color: var(--clr-primary);
    height: 4px;
}
/* Slide number */
.reveal .slide-number {
    background: transparent;
    color: var(--clr-primary);
    font-family: var(--font-body);
    font-size: 12px;
    padding: 6px 10px;
}
